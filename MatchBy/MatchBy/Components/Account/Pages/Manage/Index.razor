@page "/Account/Manage"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using MatchBy.Enums

@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject IdentityUserAccessor UserAccessor
@inject IdentityRedirectManager RedirectManager
@inject IJSRuntime JS

<PageTitle>Profile</PageTitle>

<section class="space-y-6">
    <h2 class="text-lg font-medium text-gray-900 dark:text-white mb-6">Edit Profile</h2>
    
    <StatusMessage/>
    <EditForm Model="Input" FormName="profile" OnValidSubmit="OnValidSubmitAsync" method="post" class="space-y-6">
        <DataAnnotationsValidator/>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Username (read-only) -->
            <div class="md:col-span-2">
                <label for="username" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">
                    Username
                </label>
                <input
                    id="username"
                    type="text"
                    value="@_username"
                    disabled
                    aria-readonly="true"
                    class="bg-gray-100 border border-gray-300 text-gray-600 rounded-lg block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-gray-400 cursor-not-allowed"/>
            </div>

            <!-- User Bio -->
            <div class="md:col-span-2">
                <label for="Input.Bio" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">
                    Biography
                </label>
                <InputText
                    id="Input.Bio"
                    @bind-Value="Input.Bio"
                    class="bg-gray-50 border border-gray-300 text-gray-900 rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500"
                    placeholder="Let's play together!"/>
                <ValidationMessage For="() => Input.Bio" class="text-red-600 text-sm mt-1"/>
            </div>
        </div>

        <button id="dropdownBgHoverButton" data-dropdown-toggle="dropdownBgHover" class="text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center inline-flex items-center dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800" type="button">Favorite Sports <svg class="w-2.5 h-2.5 ms-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 10 6">
        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 4 4 4-4"/>
        </svg>
        </button>

        <!-- Dropdown menu -->
        <div id="dropdownBgHover" class="z-10 hidden w-48 bg-white rounded-lg shadow-sm dark:bg-gray-700">
            <ul class="p-3 space-y-1 text-sm text-gray-700 dark:text-gray-200" aria-labelledby="dropdownBgHoverButton">
                @foreach (var sport in Enum.GetValues<Sports>()) {
                    var id = $"sport-{(int)sport}";
                    <li>
                        <label for="@id"
                            class="flex items-center p-2 rounded-sm hover:bg-gray-100 dark:hover:bg-gray-600 cursor-pointer">
                            <input id="@id"
                                type="checkbox"
                                checked="@Input.SelectedSports.Contains(sport)"
                                @onchange="e => OnSportChanged(sport, e)"
                                class="w-4 h-4 text-blue-600 bg-gray-100 border-gray-300 rounded-sm focus:ring-2 focus:ring-blue-500 dark:focus:ring-blue-600 dark:ring-offset-gray-700 dark:focus:ring-offset-gray-700 dark:bg-gray-600 dark:border-gray-500" />
                            <span class="ms-2 text-sm font-medium text-gray-900 dark:text-gray-300">@sport</span>
                        </label>
                    </li>
                }
            </ul>
        </div>

        <div class="pt-2">
            <button
                type="submit"
                class="w-full sm:w-auto inline-flex justify-center px-6 py-2.5 rounded-lg text-sm font-medium text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-4 focus:ring-primary-300 dark:bg-primary-600 dark:hover:bg-primary-700 dark:focus:ring-primary-800">
                Save
            </button>
        </div>
    </EditForm>
</section>

@code {
    private ApplicationUser _user = default!;
    private string? _username;
    private string? _bio;

    [CascadingParameter] private HttpContext HttpContext { get; set; } = default!;
    [SupplyParameterFromForm] private InputModel Input { get; set; } = new();

    protected override async Task OnAfterRenderAsync(bool firstRender) {
        await JS.InvokeVoidAsync("initFlowbite");
    }

    protected override async Task OnInitializedAsync() {
        _user = await UserAccessor.GetRequiredUserAsync(HttpContext);
        _username = await UserManager.GetUserNameAsync(_user);
        
        _bio = _user.Bio;
        Input.Bio ??= _bio;

        Input.SelectedSports = _user.PreferredSports?.ToHashSet() ?? new();
    }

    private async Task OnValidSubmitAsync() {
        var changed = false;

        if (Input.Bio != _bio) {
            _user.Bio = Input.Bio;
            var update = await UserManager.UpdateAsync(_user);
            if (!update.Succeeded)
            {
                RedirectManager.RedirectToCurrentPageWithStatus("Error: Failed to set bio.", HttpContext);
                return;
            }
            changed = true;
        }

        if (changed) {
            await SignInManager.RefreshSignInAsync(_user);
            RedirectManager.RedirectToCurrentPageWithStatus("Your profile has been updated", HttpContext);
        }
    }

    private void OnSportChanged(Sports sport, ChangeEventArgs e) {
        var isChecked = e.Value?.ToString()?.ToLower() == "true";
        if (isChecked)
            Input.SelectedSports.Add(sport);
        else
            Input.SelectedSports.Remove(sport);
    }

    private sealed class InputModel {
        [Display(Name = "Bio")]
        [StringLength(500, ErrorMessage = "Your bio must be at most 500 characters long.")]
        public string? Bio { get; set; }
        public HashSet<Sports> SelectedSports { get; set; } = new();
    }

}
