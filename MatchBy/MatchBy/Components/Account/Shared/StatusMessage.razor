@if (!string.IsNullOrEmpty(DisplayMessage))
{
    <div class="p-4 mb-4 text-sm rounded-lg @(DisplayMessage.StartsWith("Error") ? "bg-red-50 text-red-800 dark:bg-gray-800 dark:text-red-400" : "text-green-800 bg-green-50 dark:bg-gray-800 dark:text-green-400")" role="alert">
        @DisplayMessage
    </div>
}

@code {
    private string? _messageFromCookie;

    [Parameter] public string? Message { get; set; }
    [Parameter] public bool UseCookieMessage { get; set; } = true;

    [CascadingParameter] private HttpContext HttpContext { get; set; } = default!;

    private string? DisplayMessage => Message ?? _messageFromCookie;

    protected override void OnInitialized()
    {
        if (!UseCookieMessage) return;
        
        _messageFromCookie = HttpContext.Request.Cookies[IdentityRedirectManager.StatusCookieName];
        if (_messageFromCookie is not null)
        {
            HttpContext.Response.Cookies.Delete(IdentityRedirectManager.StatusCookieName);
        }
    }

}