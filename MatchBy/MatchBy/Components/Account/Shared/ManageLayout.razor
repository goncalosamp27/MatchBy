@inherits LayoutComponentBase
@layout Layout.MainLayout

<section class="max-w-7xl mx-auto px-4 lg:px-8 py-6">
    <header class="mb-6">
        <h1 class="text-3xl font-semibold text-gray-900 dark:text-white">Manage your account</h1>
        <div class="h-px bg-gray-200 dark:bg-gray-700 mt-4"></div>
    </header>
    
    <details class="lg:hidden mb-4 rounded-lg border border-gray-200 dark:border-gray-700">
        <summary class="cursor-pointer px-4 py-3 text-sm font-medium text-gray-700 dark:text-gray-300 select-none">
            Menu
        </summary>
        <div class="px-4 py-3">
            <ManageNavMenu />
        </div>
    </details>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        <aside class="hidden lg:block lg:col-span-3">
            <div class="sticky top-24">
                <ManageNavMenu />
            </div>
        </aside>
        
        <main class="lg:col-span-6">
            <div class="rounded-xl bg-gray-50 dark:bg-gray-800 ring-1 ring-gray-200 dark:ring-gray-700 shadow-sm p-6 lg:p-8">
                <div class="max-w-2xl">
                    @Body
                </div>
            </div>
        </main>

        <div class="hidden lg:block lg:col-span-3"></div>
    </div>
</section>

