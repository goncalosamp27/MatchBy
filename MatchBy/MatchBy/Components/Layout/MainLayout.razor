@using Blazorise
@inherits LayoutComponentBase

<Layout>
    <LayoutHeader>
        <Header></Header>
    </LayoutHeader>
    <LayoutContent Class="bg-[var(--background)]">
        @Body
    </LayoutContent>
    <LayoutFooter>
        <Footer></Footer>
    </LayoutFooter>
</Layout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>