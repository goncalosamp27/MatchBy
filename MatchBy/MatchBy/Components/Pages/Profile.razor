@page "/profile"

@using MatchBy.Components.Pages.Matches
@using MatchBy.Models
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@inject IMatchesService MatchesService
@inject NavigationManager Navigation
@inject ILogger<Profile> Logger

<PageTitle>Profile</PageTitle>

<section class="bg-[var(--background)] min-h-screen">
    <div class="max-w-6xl mx-auto p-6">
        <h1 class="text-xl font-semibold mb-6 text-[var(--text)]">Profile Page</h1>

        @if (user is null)
        {
            <p class="text-[var(--text)]">Loading profile...</p>
        }
        else
        {
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- Coluna Esquerda -->
                <div class="bg-[var(--section)] shadow rounded-2xl p-6 border-2 border-[var(--main)] transition duration-200 ease-out hover:shadow-[0_0px_10px_-4px_var(--main)]">
                    <div class="flex items-center gap-4">
                        <div class="w-20 h-20 rounded-full bg-gray-200 flex items-center justify-center overflow-hidden">
                            @if (user.ProfileImage is not null)
                            {
                                <img src="@user.ProfileImage.Url" alt="Profile" class="w-full h-full object-cover" />
                            }
                            else
                            {
                                <svg class="w-10 h-10 text-gray-500" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M12 12c2.67 0 8 1.34 8 4v4H4v-4c0-2.66 5.33-4 8-4zm0-2a4 4 0 1 0 0-8 4 4 0 0 0 0 8z" />
                                </svg>
                            }
                        </div>
                        <div>
                            <h2 class="font-bold text-lg text-[var(--text)]">@user.DisplayName</h2>
                            <p class="text-sm text-gray-500">@user.UserName</p>
                        </div>
                    </div>

                    <!-- Status e Rating -->
                    <div class="mt-4 flex flex-wrap gap-4 items-center">
                        <span class="px-3 py-1 bg-green-100 text-green-700 rounded-full text-sm">@user.Status</span>

                        @if (user.BaseLocation is not null)
                        {
                            <span class="text-gray-600 flex items-center text-sm">
                                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path d="M12 2C8.13 2 5 5.13 5 9c0 7 7 13 7 13s7-6 7-13c0-3.87-3.13-7-7-7z" />
                                </svg>
                                @user.BaseLocation.City, @user.BaseLocation.Country
                            </span>
                        }

                        <div class="flex items-center">
                            <span class="text-sm font-medium mr-1 text-[var(--text)]">@user.Rating.ToString("0.0")</span>
                            <div class="flex text-yellow-400">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <span class="@(i <= Math.Round(user.Rating) ? "" : "text-gray-500 dark:text-gray-600")">★</span>
                                }
                            </div>
                        </div>

                    </div>

                    <!-- Bio -->
                    <div class="mt-6">
                        <label class="block text-sm font-medium mb-1 text-[var(--text)]">Bio</label>
                        <textarea class="w-full border-2 border-[var(--main)] rounded-lg p-2 text-sm
                                        bg-[var(--section-secondary)] text-[var(--text)]
                                        shadow-sm transition duration-200 ease-out
                                        focus:outline-none focus:ring-0
                                        hover:shadow-[0_0px_10px_-4px_var(--main)]"
                                  rows="2" readonly
                                  style="cursor: default; user-select: text;">@user.Bio</textarea>
                    </div>

                    <!-- Email -->
                    <div class="mt-4">
                        <label class="block text-sm font-medium mb-1 text-[var(--text)]">Email</label>
                        <input type="email" value="@user.Email"
                               class="w-full border-2 border-[var(--main)] rounded-lg p-2 text-sm
                                      bg-[var(--section-secondary)] text-[var(--text)]
                                      shadow-sm transition duration-200 ease-out
                                      focus:outline-none focus:ring-0
                                      hover:shadow-[0_0px_10px_-4px_var(--main)]"
                               readonly
                               style="cursor: default; user-select: text;" />
                    </div>
                </div>

                <!-- Coluna Direita -->
                <div class="bg-[var(--section)] shadow-sm rounded-2xl p-6 border-2 border-[var(--main)]
                            transition duration-200 ease-out hover:shadow-[0_0px_10px_-4px_var(--main)]">
                    <h3 class="font-semibold mb-4 text-[var(--text)]">Preferred Sports</h3>
                    <div class="grid grid-cols-2 gap-4">
                        @if (user.PreferredSports?.Any() == true)
                        {
                            @foreach (var sport in user.PreferredSports)
                            {
                                <div class="flex items-center justify-center border-2 border-[var(--main)]
                                            rounded-xl p-3 text-[var(--text)] bg-[var(--section-secondary)]
                                            transition duration-200 ease-out
                                            hover:shadow-[0_0px_10px_-4px_var(--main)]">
                                    @sport
                                </div>
                            }
                        }
                        else
                        {
                            <p class="text-sm text-gray-500 col-span-2">No preferred sports selected.</p>
                        }
                    </div>
                </div>
            </div>

            <!-- Matches -->
            <div class="mt-10 grid grid-cols-1 md:grid-cols-2 gap-8">
                <div>
                    <h3 class="font-semibold mb-4 text-[var(--text)]">Previous Matches</h3>
                    <div class="bg-[var(--section)] shadow rounded-xl p-6 border-2 border-[var(--main)]">
                        @if (matches?.Any() == true)
                        {
                            <div class="flex flex-col gap-6">
                                <!-- espaçamento entre cards -->
                                @foreach (var match in matches)
                                {
                                    <div class="rounded-xl border-2 border-[var(--main)] bg-[var(--section-secondary)]
                                    shadow-sm overflow-hidden transition duration-200 ease-out
                                    hover:shadow-[0_0px_10px_-4px_var(--main)]">
                                        <MatchCard Match="@match" />
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-sm text-gray-500">No previous matches found.</p>
                        }
                    </div>
                </div>

                <div>
                    <h3 class="font-semibold mb-4 text-[var(--text)]">Created Matches</h3>
                    <NavLink href="/CreateMatch"
                             class="border-2 border-dashed border-[var(--main)] rounded-xl flex flex-col items-center justify-center p-10 bg-[var(--section)]
                        hover:bg-[var(--section-secondary)] hover:shadow-[0_0px_10px_-4px_var(--main)] cursor-pointer transition">
                        <svg class="w-10 h-10 text-gray-400 mb-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M12 4v16m8-8H4" />
                        </svg>
                        <p class="text-gray-500 text-sm font-medium">Create New Match</p>
                    </NavLink>
                </div>
            </div>
 
        }
    </div>
</section>

@code {
    private ApplicationUser? user;
    private List<Match>? matches;

    [CascadingParameter] private HttpContext HttpContext { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            user = await UserManager.GetUserAsync(HttpContext.User);
            matches = await MatchesService.GetCompletedMatches();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading user profile");
        }
    }
}
