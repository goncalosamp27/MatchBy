@using MatchBy.DTOs.Team

@if (Team is null)
{
    <div class="p-4 text-[var(--text)]">No team data available.</div>
    return;
}

<a href="@("/teams/" + Team.Id)"
   class="h-full flex flex-col md:flex-row bg-[var(--section)] border-2 border-[var(--main)] rounded-lg shadow-sm md:items-stretch
          transform transition duration-200 ease-out
          hover:-translate-y-1 hover:shadow-[0_0px_10px_-4px_var(--main)]
          focus-visible:-translate-y-1">

    <div class="md:basis-2/5 md:flex-none">
        <img class="object-cover w-full h-64 md:h-full rounded-t-lg md:rounded-none md:rounded-s-lg" src="/images/sports/football.jpg" alt="@Team!.Name" />
    </div>

    <div class="md:basis-3/5 flex flex-col justify-between p-4 leading-normal">
        <h5 class="mb-2 text-xl font-bold tracking-tight text-[var(--main)]">
            @Team!.Name
        </h5>

        <p class="mb-2 font-normal text-[var(--text)] line-clamp-2">@Team!.Description</p>
        <p class="mb-2 font-normal text-[var(--text)]">
            Created: @Team!.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy")
        </p>
        <p class="mb-3 font-normal text-[var(--text)]">
            Owner: @(Team!.Owner?.DisplayName ?? "Unknown")
        </p>
        <p class="text-sm text-[var(--main)]">
            Members: @Team!.Members.Count
        </p>
    </div>
</a>


@code {
    [Parameter] public TeamDto? Team { get; set; }
}
