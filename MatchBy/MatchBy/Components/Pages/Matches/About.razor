@page "/About"
@using Blazorise
@rendermode @(new InteractiveServerRenderMode(false))
@inject NavigationManager Nav


<PageTitle>About MatchBy</PageTitle>

<section class="bg-[var(--background)]">
    <section class ="border-b-0 border-[var(--main)]">

        <div class="grid max-w-screen-xl h-auto px-4 mx-auto py-8 lg:py-16 lg:grid-cols-12 md:justify-center">
            <div class="mr-auto place-self-center lg:col-span-7">
                <h1 class="text-[var(--main)] max-w-2xl mb-4 text-4xl font-bold leading-tight tracking-tight md:text-3xl xl:text-4xl text-center">Our mission</h1>
                <div class="max-w-2xl mb-6 font-light text-[var(--text)] text-justify lg:mb-8 md:text-lg lg:text-xl lg:text-left leading-relaxed">
                    Meeting people nearby who share your passion for sports isn't always easy...
                    MatchBy's mission is to bring players together, helping you find teammates, organize games,
                    and enjoy your favorite sports without the hassle. Fast, simple, and built for everyone.
                </div>
            </div>
            <div class="hidden lg:mt-0 lg:col-span-5 lg:flex items-center justify-center">
                <img src="images/about/mission.png" alt="football" class="max-w-full h-[300px] w-auto object-contain object-center" />
            </div>
        </div>

        <div class="grid max-w-screen-xl h-auto px-4 mx-auto py-8 lg:py-16 lg:grid-cols-12 md:justify-center">
            <div class="hidden lg:mt-0 lg:col-span-5 lg:flex items-center justify-center">
                <img src="images/carousel/beachvolleyball.png" alt="football" class="max-w-full h-[300px] w-auto object-contain object-center" />
            </div>
            <div class="mr-auto place-self-center lg:col-span-7">
                <h1 class="text-[var(--main)] max-w-2xl mb-4 text-4xl font-bold leading-tight tracking-tight md:text-3xl xl:text-4xl text-center">What we offer</h1>
                <p class="max-w-2xl mb-6 font-light text-[var(--text)] text-justify lg:mb-8 md:text-lg lg:text-xl lg:text-left leading-relaxed">
                    MatchBy is the best way to connect with other players and organize matches. Start playing today!
                    MatchBy is the best way to connect with other players and organize matches. Start playing today!
                    MatchBy is the best way to connect with other players and organize matches. Start playing today!
                    MatchBy is the best way to connect with other players and organize matches. Start playing today!
                </p>
            </div>
        </div>

    </section>
</section>