@page "/Matches"
@using Blazorise
@using MatchBy.Services.Matches
@inject IMatchesService MatchesService
@inject NavigationManager NavigationManager
@rendermode @(new InteractiveServerRenderMode(false))
@attribute [StreamRendering]
@inject AuthenticationStateProvider AuthenticationStateProvider
@using System.Security.Claims
@using MatchBy.DTOs.Match
@inject IJSRuntime JS

<section class="bg-[var(--background)]">
    <div class="grid max-w-screen-xl h-auto mx-auto px-4 justify-center">
        <div class="grid max-full h-auto px-4 mx-auto py-8 lg:gap-8 xl:gap-0 lg:py-32 lg:grid-cols-12 md:justify-center">
            <div class="mr-auto place-self-center lg:col-span-7">
                <h1 class="text-[var(--text)] max-w-2xl mb-4 text-4xl font-bold leading-tight tracking-tight md:text-5xl xl:text-6xl lg:text-left text-center">Find your next Match!</h1>
                <p class="max-w-2xl mb-6 font-light text-[var(--main)] lg:mb-8 md:text-lg lg:text-xl lg:text-left text-center leading-relaxed">Are you looking for matches of your favorite sports to attend?</p>
                <div class="flex lg:justify-start justify-center">
                    <a href="/SearchMatches" class="inline-flex items-center justify-center px-5 py-3 mr-3 text-base font-medium text-center text-[var(--text)] rounded-lg bg-[var(--main)] hover:bg-[var(--main-hover)] text-[var(--text-contrast)] hover:text-[var(--text)]">
                        Search Matches
                        <svg class="w-5 h-5 ml-2 -mr-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                        <path stroke="currentColor" stroke-linecap="round" stroke-width="2" d="m21 21-3.5-3.5M17 10a7 7 0 1 1-14 0 7 7 0 0 1 14 0Z"/>
                        </svg>
                    </a>
                    <a href="/CreateMatch" class="inline-flex items-center justify-center px-5 py-3 text-base font-medium text-center text-[var(--text)] border border-[var(--text)] rounded-lg hover:text-[var(--main)] hover:border-[var(--main)]">
                        Create Match
                    </a>
                </div>
            </div>
        </div>

        @if (isAuthenticated) {
            @if (yourCreatedMatches is null) { <Loading></Loading> }
            else {   
                if (yourCreatedMatches.Count > 0){
                    <h1 class="text-3xl font-semibold text-[var(--text)] mb-8">Matches By you:</h1>
                    <div class="grid gap-6 mx-auto justify-items-center grid-cols-1 md:grid-cols-3 mb-8">
                        @foreach (var match in yourCreatedMatches)
                        {
                            <MatchCard Match="@match" />
                        }
                    </div>
                }
            }

            @if (attendingMatches is null) { <Loading></Loading> }
            else {   
                if (attendingMatches.Count > 0){
                    <h1 class="text-3xl font-semibold text-[var(--text)] mb-8">Your upcoming Matches:</h1>
                    <div class="grid gap-6 mx-auto justify-items-center grid-cols-1 md:grid-cols-3 mb-8">
                        @foreach (var match in attendingMatches) {
                            <MatchCard Match="@match" />
                        }
                    </div>
                }
            }
        }
    </div>
</section>

@code {
    private bool isAuthenticated;
    private List<MatchDto>? yourCreatedMatches { get; set; }
    private List<MatchDto>? attendingMatches { get; set; }

    public class BrowserLocation
    {
        public double latitude { get; set; }
        public double longitude { get; set; }
    }

    [CascadingParameter] private HttpContext HttpContext { get; set; } = default!;
    private string? _userId;

    protected override async Task OnInitializedAsync() {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        isAuthenticated = user.Identity?.IsAuthenticated ?? false;

        if (!isAuthenticated) {
            yourCreatedMatches = null;
            attendingMatches = null;
            return;
        }

        // If authenticated, load matches by user and attending
        _userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (string.IsNullOrEmpty(_userId)) {    
            yourCreatedMatches = [];
            attendingMatches = [];
            return;
        }
        
        var result = await MatchesService.GetMatchesForUser(_userId, null, 1, 5, CancellationToken.None);
        if (!result.Success) {
            Console.WriteLine("Error fetching user matches: " + result.ErrorMessages);
            return;
        }
        yourCreatedMatches = result.Data!.Data;
        
        var attendingResult = await MatchesService.GetMatchesUserAttending(_userId, null, 1, 5, CancellationToken.None);
        if (!attendingResult.Success) {
            Console.WriteLine("Error fetching attending matches: " + attendingResult.ErrorMessages);
            return;
        }
        attendingMatches = attendingResult.Data!.Data;
    }
}