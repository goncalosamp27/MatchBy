@page "/chat"

@using MatchBy.DTOs.Chat.Conversations
@using MatchBy.DTOs.Chat.Messages
@using MatchBy.Services.ChatMessages
@using MatchBy.Services.Conversations
@using MatchBy.Services.Users
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.SignalR.Client
@attribute [Authorize]
@rendermode InteractiveServer
@inject AuthenticationStateProvider Auth
@inject IConversationService ConversationService
@inject IChatMessageService ChatMessageService
@inject IUsersService UsersService
@inject ChatState State
@inject NavigationManager NavigationManager

<div class="fixed inset-0 flex flex-col bg-white dark:bg-neutral-900 text-neutral-900 dark:text-neutral-100">
    <div class="mt-14 flex flex-1 min-h-0">
        <div class="w-72 hidden md:flex flex-col border-r border-gray-200 dark:border-neutral-800">
            <ChatSidebar Conversations="State.Conversations"
                         OnConversationSelected="OnConversationSelected"
                         OnShowModal="ShowModal"/>
        </div>

        <main class="flex-1 flex flex-col min-w-0 min-h-0">
            @if (State.Selected is null)
            {
                <ChatEmptyState/>
            }
            else
            {
                <ChatHeader Conversation="State.Selected" OnOpenInfo="ShowOffcanvas"/>
                <MessageList ChatMessages="@State.MessagesOfSelectedConversation"
                             CurrentUserId="@State.UserId"
                             OnEdit="OnEditMessage"
                             OnReply="OnReplyToMessage"
                             OnDelete="OnDeleteMessage"/>
                <ChatFooter Text="@_messageText"
                            TextChanged="(v => _messageText = v)"
                            ReplyTo="@_replyToMessage"
                            OnCancelReply="CancelReply"
                            OnSend="HandleSubmit"/>
            }
        </main>
    </div>

    @if (State.Selected is not null)
    {
        <ConversationInfoOffcanvas @ref="_offcanvas"
                                   SelectedConversation="@State.Selected"
                                   OnLeaveConversation="LeaveConversation"
                                   OnDeleteConversation="DeleteConversation"
                                   OnImageSubmit="OnUpdateConversation"
                                   UserId="@State.UserId"/>
    }

    <NewConversationModal @ref="_modal"
                          OnCreate="StartChat"
                          Users="@_allUsers"/>
</div>

@code{
    private ConversationInfoOffcanvas _offcanvas = default!;
    private NewConversationModal _modal = default!;
    private string? _messageText;
    private ChatMessageDto? _replyToMessage;
    private IReadOnlyList<ApplicationUser> _allUsers = [];

    // SignalR Hub Connection
    private HubConnection? _hubConnection;
    private bool IsConnected => _hubConnection?.State == HubConnectionState.Connected;

    protected override async Task OnInitializedAsync()
    {
        State.Changed += (_, _) => StateHasChanged();
        var user = (await Auth.GetAuthenticationStateAsync()).User;
        var userId = user.FindFirst(u => u.Type.Contains("nameidentifier"))?.Value;
        if (userId is null) return;
        
        State.InitUser(userId);
        var conversations = await ConversationService.GetConversationsAsync(userId);
        State.SetConversations(conversations);

        // Load all users except the current user
        _allUsers = await UsersService.GetUsers();
        _allUsers = _allUsers.Where(u => u.Id != userId).ToList();
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(NavigationManager.ToAbsoluteUri("/hubs/chat"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<ChatMessageDto>("MessageCreated", message =>
        {
            Console.WriteLine($"Received message via SignalR: {message.Content}");
            
            //to run in UI thread, so it can update the state
            InvokeAsync(() =>
            {
                State.UpsertMessage(message);
            });
        });
        
        _hubConnection.On<ChatMessageDto>("MessageUpdated", message =>
        {
            Console.WriteLine($"Updated message via SignalR: {message.Content}");
            
            //to run in UI thread, so it can update the state
            InvokeAsync(() =>
            {
                State.UpsertMessage(message);
            });
        });
        
        _hubConnection.On<ConversationDto, string>("MessageDeleted",( conversation, chatMessageId) =>
        {
            Console.WriteLine($"Deleted message via SignalR: {chatMessageId}");
            
            //to run in UI thread, so it can update the state
            InvokeAsync(() =>
            {
                State.RemoveMessage(conversation, chatMessageId);
            });
        });
        
        _hubConnection.On<ConversationDto>("ConversationCreated", conversation =>
        {
            Console.WriteLine($"Received conversation via SignalR: {conversation.Title}");
            
            //to run in UI thread, so it can update the state
            InvokeAsync(async () =>
            {
                State.Conversations.Add(conversation);
                await OnConversationSelected(conversation);
            });
        });
        
        _hubConnection.On<ConversationDto>("ConversationUpdated", conversation =>
        {
            Console.WriteLine($"Updated conversation via SignalR: {conversation.Title}");
            
            //to run in UI thread, so it can update the state
            InvokeAsync(() =>
            {
                State.UpdateConversation(conversation);
            });
        });
        
        _hubConnection.On<string>("ConversationDeleted", conversationId =>
        {
            Console.WriteLine($"Deleted conversation via SignalR: {conversationId}");
            
            //to run in UI thread, so it can update the state
            InvokeAsync(() =>
            {
                State.RemoveConversation(conversationId);
            });
        });
        
        _hubConnection.On<ConversationDto>("ConversationLeft", conversation =>
        {
            Console.WriteLine($"Leave conversation via SignalR: {conversation}");
            
            //to run in UI thread, so it can update the state
            InvokeAsync(() =>
            {
                if(conversation.Participants.All(p => p.Id != State.UserId))
                {
                    State.RemoveConversation(conversation.Id);
                }
                else
                {
                    State.UpdateConversation(conversation);
                }
            });
        });
        
        _hubConnection.Closed += error =>
        {
            Console.WriteLine($"Connection closed: {error?.Message}");
            return Task.CompletedTask;
        };

        _hubConnection.Reconnecting += error =>
        {
            Console.WriteLine($"Connection reconnecting: {error?.Message}");
            return Task.CompletedTask;
        };

        _hubConnection.Reconnected += async connectionId =>
        {
            Console.WriteLine($"Connection reconnected: {connectionId}");
            await JoinAllConversations();
        };

        try
        {
            await _hubConnection.StartAsync();
            Console.WriteLine($"SignalR Connected: {IsConnected}");
            
            await _hubConnection.InvokeAsync("Register", State.UserId);
        
            await JoinAllConversations();
            Console.WriteLine($"Joined all conversations");
        
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error connecting to SignalR: {ex.Message}");
        }
    }
    
    
    private async Task JoinAllConversations()
    {
        if (!IsConnected || _hubConnection is null) return;

        var tasks = State.Conversations.Select(conv => _hubConnection.InvokeAsync("JoinConversation", conv.Id)).ToList();

        if (tasks.Count > 0)
            await Task.WhenAll(tasks);
    }

    private Task ShowOffcanvas() => _offcanvas.Show();
    private Task ShowModal() => _modal.Show();

    private async Task HandleSubmit()
    {
        Console.WriteLine($"Sending message: {_messageText}");
        if (string.IsNullOrWhiteSpace(_messageText) || State.Selected is null) return;

        CreateChatMessageDto createChatMessageDto = new()
        {
            Content = _messageText,
            CreatorUserId = State.UserId!,
            ConversationId = State.Selected.Id,
            ReplyToMessageId = _replyToMessage?.Id
        };

        if (_hubConnection is not null)
        {
            await _hubConnection.SendAsync("CreateMessage", createChatMessageDto);
        }
        
        _messageText = null;
        _replyToMessage = null;

        Console.WriteLine($"Message sent successfully: {createChatMessageDto.Content}");
    }

    private async Task OnEditMessage(UpdateChatMessageDto msg)
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.SendAsync("UpdateMessage", msg);
        }
    }

    private async Task OnDeleteMessage(ChatMessageDto msg)
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.SendAsync("DeleteMessage", msg.Id);
        }
    }

    private Task OnReplyToMessage(ChatMessageDto msg)
    {
        _replyToMessage = msg;
        return Task.CompletedTask;
    }

    private Task CancelReply()
    {
        _replyToMessage = null;
        return Task.CompletedTask;
    }

    private async Task StartChat(string otherUserId)
    {
        var createConversationDto = new CreateConversationDto
        {
            CreatorUserId = State.UserId!,
            ConversationType = ConversationType.Private,
            ParticipantIds = [otherUserId, State.UserId],
            TeamId = null,
            MatchId = null,
            Title = null
        };
        
        if (_hubConnection is not null)
        {
            await _hubConnection.SendAsync("CreateConversation", createConversationDto);
        }
    }

    private async Task LeaveConversation()
    {
        var id = State.Selected?.Id;
        if (id is null) return;
        
        if(_hubConnection is not null)
        {
            await _hubConnection.SendAsync("LeaveConversationAndNotify", id);
        }
    }

    private async Task DeleteConversation()
    {
        var id = State.Selected?.Id;
        if (id is null) return;
        if(_hubConnection is not null)
        {
            await _hubConnection.SendAsync("DeleteConversation", id);
        }
    }

    public async Task OnConversationSelected(ConversationDto conversation)
    {
        var messages = await ChatMessageService.GetChatMessagesAsync(conversation.Id, State.UserId);
        State.Select(conversation, messages);
    }

    public async Task OnUpdateConversation(UpdateConversationDto updateConversationDto)
    {
        if (State.Selected is null)
        {
            Console.WriteLine("No conversation selected.");
            return;
        }


        ConversationDto? conv = await ConversationService.UpdateConversationAsync(updateConversationDto);
        if (conv is null)
        {
            Console.WriteLine("Failed to update conversation.");
            return;
        }
        
        State.UpdateConversation(conv);
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }
    }

}
