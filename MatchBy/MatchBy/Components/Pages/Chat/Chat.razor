@page "/chat"
@rendermode InteractiveServer

<div class="h-[100dvh] md:h-[100svh] bg-white dark:bg-neutral-900 text-neutral-900 dark:text-neutral-100">
    <!-- Layout em 2 colunas (sidebar + conteúdo). Colapsa a sidebar em ecrãs pequenos -->
    <div class="grid grid-cols-1 md:grid-cols-[18rem_1fr] h-full">

        <!-- Sidebar -->
        <aside
            class="hidden md:flex md:flex-col bg-white dark:bg-neutral-900 border-r border-gray-200 dark:border-neutral-800">

            <!-- header -->
            <div class="px-4 pt-3 pb-2">
                <div class="flex items-center justify-between">
                    <h2 class="text-[15px] font-semibold text-gray-900 dark:text-gray-100">Chats</h2>
                    <button class="p-1.5 rounded hover:bg-gray-100 dark:hover:bg-neutral-800">
                        <svg class="size-4 text-gray-500 dark:text-gray-400" viewBox="0 0 20 20" fill="currentColor">
                            <path
                                d="M6 10a2 2 0 11-4 0 2 2 0 014 0zm6 0a2 2 0 11-4 0 2 2 0 014 0zm6 0a2 2 0 11-4 0 2 2 0 014 0z"/>
                        </svg>
                    </button>
                </div>

                <!-- search -->
                <label class="relative mt-2 block">
                    <input type="search"
                           class="w-full rounded-lg border border-gray-300 dark:border-neutral-700 bg-white dark:bg-neutral-900 pl-9 pr-3 py-2 text-sm placeholder-gray-400 dark:placeholder-neutral-500 outline-none focus:ring-2 focus:ring-blue-500/30"
                           placeholder="Search for messages or contacts"/>
                    <svg class="size-5 absolute left-2.5 top-2.5 text-gray-400 dark:text-neutral-500"
                         viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                              d="m21 21-4.3-4.3m0-6.2a7.5 7.5 0 1 1-15 0 7.5 7.5 0 0 1 15 0Z"/>
                    </svg>
                </label>
            </div>

            <!-- list -->
            <nav class="flex-1 overflow-y-auto thin-scroll px-2 pb-3 space-y-4">

                <!-- PRIVATE CONVERSATIONS -->
                <div>
                    <div class="px-2 pt-1 pb-2 text-xs uppercase tracking-wide text-gray-500 dark:text-neutral-400">
                        Private conversations
                    </div>

                    <button
                        class="w-full flex items-start gap-3 px-2 py-2 rounded-lg hover:bg-gray-50 dark:hover:bg-neutral-800">
        <span class="relative">
          <img class="size-10 rounded-full" src="https://i.pravatar.cc/40?img=15" alt="">
          <span
              class="absolute -bottom-0.5 -right-0.5 size-2.5 rounded-full bg-emerald-500 ring-2 ring-white dark:ring-neutral-900"></span>
        </span>
                        <span class="min-w-0 flex-1 text-left">
          <span class="flex items-center justify-between">
            <span class="text-[15px] font-medium truncate">Lana Byrd</span>
            <span class="text-[11px] text-gray-500">16h</span>
          </span>
          <span class="mt-0.5 text-xs text-gray-500 dark:text-neutral-400 truncate">🎉 Awesome, let’s go!</span>
        </span>
                    </button>

                    <button
                        class="w-full flex items-start gap-3 px-2 py-2 rounded-lg hover:bg-gray-50 dark:hover:bg-neutral-800">
        <span class="relative">
          <img class="size-10 rounded-full" src="https://i.pravatar.cc/40?img=32" alt="">
          <span
              class="absolute -bottom-0.5 -right-0.5 size-2.5 rounded-full bg-rose-500 ring-2 ring-white dark:ring-neutral-900"></span>
        </span>
                        <span class="min-w-0 flex-1 text-left">
          <span class="flex items-center justify-between">
            <span class="text-[15px] font-medium truncate">Helene Engels</span>
            <span class="text-[11px] text-gray-500">18h</span>
          </span>
          <span class="mt-0.5 text-xs text-gray-500 dark:text-neutral-400 truncate">Yes, we can do this! 🔥</span>
        </span>
                    </button>
                </div>

                <!-- MATCH CONVERSATIONS -->
                <div>
                    <div class="px-2 pt-1 pb-2 text-xs uppercase tracking-wide text-gray-500 dark:text-neutral-400">
                        Match conversations
                    </div>

                    <button
                        class="w-full flex items-start gap-3 px-2 py-2 rounded-lg hover:bg-gray-50 dark:hover:bg-neutral-800">
        <span class="relative">
          <img class="size-10 rounded-full" src="https://i.pravatar.cc/40?img=8" alt="">
          <span
              class="absolute -bottom-0.5 -right-0.5 size-2.5 rounded-full bg-emerald-500 ring-2 ring-white dark:ring-neutral-900"></span>
        </span>
                        <span class="min-w-0 flex-1 text-left">
          <span class="flex items-center justify-between">
            <span class="text-[15px] font-medium truncate">Joseph McFall</span>
            <span class="text-[11px] text-gray-500">04.03.2025</span>
          </span>
          <span class="mt-0.5 text-xs text-gray-500 dark:text-neutral-400 truncate">Let's do it next month</span>
        </span>
                    </button>

                    <button
                        class="w-full flex items-start gap-3 px-2 py-2 rounded-lg hover:bg-gray-50 dark:hover:bg-neutral-800">
                        <img class="size-10 rounded-full" src="https://i.pravatar.cc/40?img=70" alt="">
                        <span class="min-w-0 flex-1 text-left">
          <span class="flex items-center justify-between">
            <span class="text-[15px] font-medium truncate">Jese Leos</span>
            <span class="text-[11px] text-gray-500">04.03.2025</span>
          </span>
          <span class="mt-0.5 text-xs text-gray-500 dark:text-neutral-400 truncate">You hear about Flowbite? 👀</span>
        </span>
                    </button>
                </div>

                <!-- TEAM CONVERSATIONS -->
                <div>
                    <div class="px-2 pt-1 pb-2 text-xs uppercase tracking-wide text-gray-500 dark:text-neutral-400">Team
                        conversations
                    </div>

                    <button
                        class="w-full flex items-start gap-3 px-2 py-2 rounded-lg hover:bg-gray-50 dark:hover:bg-neutral-800">
                        <div class="size-10 rounded-full bg-gray-200 dark:bg-neutral-700 grid place-content-center">👥
                        </div>
                        <span class="min-w-0 flex-1 text-left">
          <span class="flex items-center justify-between">
            <span class="text-[15px] font-medium truncate">Business group</span>
            <span class="text-[11px] text-gray-500">18:05</span>
          </span>
          <span class="mt-0.5 flex items-center gap-1 text-xs text-gray-500 dark:text-neutral-400 truncate">
            Bonnie: Wait! What test? 🤔
          </span>
        </span>
                    </button>

                    <button
                        class="w-full flex items-start gap-3 px-2 py-2 rounded-lg hover:bg-gray-50 dark:hover:bg-neutral-800">
                        <div class="size-10 rounded-full bg-gray-200 dark:bg-neutral-700 grid place-content-center">👪
                        </div>
                        <span class="min-w-0 flex-1 text-left">
          <span class="flex items-center justify-between">
            <span class="text-[15px] font-medium truncate">Family group</span>
            <span class="text-[11px] text-gray-500">18:05</span>
          </span>
          <span class="mt-0.5 flex items-center gap-1 text-xs text-gray-500 dark:text-neutral-400 truncate">
            Jese: Pizza is here! 🍕
          </span>
        </span>
                    </button>
                </div>

            </nav>
        </aside>


        <!-- Conteúdo (chat) -->
        <main class="flex flex-col h-full">
            <!-- Header sticky -->
            <header
                class="sticky top-0 z-10 bg-white/80 dark:bg-neutral-900/80 backdrop-blur border-b border-gray-200/80 dark:border-neutral-800 px-4 py-3">
                <div class="flex items-center gap-3">
                    <img class="size-9 rounded-full"
                         src="https://flowbite.com/application-ui/demo/images/users/roberta-casas.png"
                         alt="Jese image">
                    <div class="min-w-0">
                        <div class="font-semibold truncate">Joseph McFall</div>
                        <div class="text-xs text-emerald-600 dark:text-emerald-400">Online</div>
                    </div>
                    <div class="ml-auto flex items-center gap-2">
                        <button class="px-2 py-1 rounded hover:bg-gray-100 dark:hover:bg-neutral-800">🔍</button>
                        <button class="px-2 py-1 rounded hover:bg-gray-100 dark:hover:bg-neutral-800">⋯</button>
                    </div>
                </div>
            </header>

            <!-- Corpo das mensagens (única área com scroll) -->
            <section class="flex-1 overflow-y-auto px-4 py-3 space-y-4">
                <ChatMessage></ChatMessage>
                <ChatMessage></ChatMessage>
                <ChatMessage></ChatMessage>
                <ChatMessage></ChatMessage>
                <ChatMessage></ChatMessage>
            </section>

            <!-- Footer sticky -->
            <footer
                class="sticky bottom-0 bg-white dark:bg-neutral-900 border-t border-gray-200/80 dark:border-neutral-800 px-3 py-2">
                <form class="flex flex-col gap-2">
                    <div class="flex flex-row gap-2">
                <textarea rows="1" placeholder="Escreve uma mensagem…"
                          class="w-full resize-none rounded-lg border border-gray-300 dark:border-neutral-700 bg-white dark:bg-neutral-900 px-3 py-2 outline-none focus:ring focus:ring-indigo-500/30"></textarea>
                        <button type="submit"
                                class="shrink-0 rounded-lg px-4 py-2 bg-indigo-600 text-white hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500/40">
                            Enviar
                        </button>
                    </div>
                    <!-- barra de ações -->
                    <div class="mt-1 flex items-center gap-2 text-sm text-gray-500">
                        <button type="button" class="px-2 py-1 rounded hover:bg-gray-100 dark:hover:bg-neutral-800">B
                        </button>
                        <button type="button" class="px-2 py-1 rounded hover:bg-gray-100 dark:hover:bg-neutral-800">I
                        </button>
                        <button type="button" class="px-2 py-1 rounded hover:bg-gray-100 dark:hover:bg-neutral-800">🙂
                        </button>
                    </div>
                </form>
            </footer>
        </main>
    </div>
</div>
