@page "/chat"

@using System.Text.Json
@using FluentValidation
@using MatchBy.DTOs.Chat.Conversations
@using MatchBy.DTOs.Chat.Messages
@using MatchBy.Services.ChatMessages
@using MatchBy.Services.Conversations
@using MatchBy.Services.Users
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.SignalR.Client
@using MatchBy.Hubs
@using Blazorise
@attribute [Authorize]
@rendermode InteractiveServer
@inject AuthenticationStateProvider Auth
@inject IConversationService ConversationService
@inject IChatMessageService ChatMessageService
@inject IUsersService UsersService
@inject ChatState State
@inject NavigationManager NavigationManager
@inject IValidator<CreateChatMessageDto> CreateChatMessageDtoValidator
@inject IValidator<UpdateChatMessageDto> UpdateChatMessageDtoValidator
@inject IValidator<CreateConversationDto> CreateConversationDtoValidator
@inject IValidator<UpdateConversationDto> UpdateConversationDtoValidator
@inject IToastService ToastService 

<div class="fixed inset-0 flex flex-col bg-white dark:bg-neutral-900 text-neutral-900 dark:text-neutral-100">
    <div class="mt-14 flex flex-1 min-h-0">
        <div class="w-72 hidden md:flex flex-col border-r border-gray-200 dark:border-neutral-800">
            <ChatSidebar Conversations="State.Conversations"
                         OnConversationSelected="OnConversationSelected"
                         OnShowModal="ShowModal"
                         OnNext="LoadMoreConversations"
                         NextCursor="@State.NextConversationCursor"
                         CurrentUserId="@State.UserId"
                         />
        </div>

        <main class="flex-1 flex flex-col min-w-0 min-h-0">
            @if (State.Selected is null)
            {
                <ChatEmptyState/>
            }
            else
            {
                <ChatHeader Conversation="State.Selected" OnOpenInfo="ShowOffcanvas" CurrentUserId="@State.UserId"/>
                <MessageList ChatMessages="@State.MessagesOfSelectedConversation"
                             CurrentUserId="@State.UserId"
                             OnEdit="OnEditMessage"
                             OnReply="OnReplyToMessage"
                             OnDelete="OnDeleteMessage"
                             OnNext="LoadMoreMessages"
                             NextCursor="@State.NextChatMessagesCursor"
                             />
                <ChatFooter Text="@_messageText"
                            TextChanged="(v => _messageText = v)"
                            ReplyTo="@_replyToMessage"
                            OnCancelReply="CancelReply"
                            OnSend="HandleSubmit"/>
            }
        </main>
    </div>

    @if (State.Selected is not null)
    {
        <ConversationInfoOffcanvas @ref="_offcanvas"
                                   SelectedConversation="@State.Selected"
                                   OnLeaveConversation="LeaveConversation"
                                   OnDeleteConversation="DeleteConversation"
                                   OnImageSubmit="OnUpdateConversation"
                                   CurrentUserId="@State.UserId"/>
    }

    <NewConversationModal @ref="_modal"
                          OnCreate="StartChat"
                          OnGetUsers="GetUsers"
                          Users="@_allUsers"/>
    
    <ToastProvider Placement="ToasterPlacement.TopEnd" Class="mt-12"/>
</div>

@code{
    private ConversationInfoOffcanvas _offcanvas = default!;
    private NewConversationModal _modal = default!;
    private string? _messageText;
    private ChatMessageDto? _replyToMessage;
    private PaginationResponse<List<ApplicationUser>> _allUsers = new();

    // SignalR Hub Connection
    private HubConnection? _hubConnection;
    private bool IsConnected => _hubConnection?.State == HubConnectionState.Connected;

    protected override async Task OnInitializedAsync()
    {
        State.Changed += (_, _) => StateHasChanged();
        var user = (await Auth.GetAuthenticationStateAsync()).User;
        var userId = user.FindFirst(u => u.Type.Contains("nameidentifier"))?.Value;
        if (userId is null) return;

        State.InitUser(userId);
        var conversations = await ConversationService.GetConversationsAsync(userId, 3, null, CancellationToken.None);
        if (!conversations.Success)
        {
            Console.WriteLine("Failed to load conversations.");
        }

        State.AddConversations(conversations.Data!);

        // Load all users except the current user
        await GetUsers(new NewConversationModal.UsersQuery("",1,4));
    }
    
    public async Task LoadMoreConversations(string? nextCursor)
    {
        if (string.IsNullOrEmpty(nextCursor)) return;

        var conversations = await ConversationService.GetConversationsAsync(State.UserId, 10, nextCursor, CancellationToken.None);
        if (!conversations.Success)
        {
            await ToastService.Error("Failed to load more conversations.");
            return;
        }

        State.AddConversations(conversations.Data!);
    }
    
    public async Task LoadMoreMessages(string? nextCursor)
    {
        if (State.Selected is null || string.IsNullOrEmpty(nextCursor)) return;

        var messagesResult = await ChatMessageService.GetChatMessagesAsync(State.Selected.Id, State.UserId, 1, nextCursor, CancellationToken.None);
        if (!messagesResult.Success)
        {
            await ToastService.Error("Failed to load more messages.");
            return;
        }

        State.AddMessages(messagesResult.Data!);
    }

    private async Task GetUsers(NewConversationModal.UsersQuery usersQuery)
    {
        var response = await UsersService.GetUsers(usersQuery.q, usersQuery.page, usersQuery.pageSize);
        if (response.Success)
        {
            _allUsers = response.Data!;
        }
        else
        {
            await ToastService.Error("Failed to load users.");
        }
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(NavigationManager.ToAbsoluteUri("/hubs/chat"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<Result<ChatMessageDto>>("MessageCreated", result =>
        {
            return InvokeAsync(async () =>
            {
                if (result.Success)
                {
                    State.UpsertMessage(result.Data!);
                }
                else
                {
                    await ToastService.Error(string.Join(", ", result.ErrorMessages));
                }
            });
        });

        _hubConnection.On<Result<ChatMessageDto>>("MessageUpdated", result =>
        {
            InvokeAsync(() =>
            {
                if (result.Success)
                {
                    Console.WriteLine($"Updated message via SignalR: {result.Data!.Content}");
                    State.UpsertMessage(result.Data!);
                }
                else
                {
                    Console.WriteLine($"Failed to update message: {string.Join(", ", result.ErrorMessages)}");
                    ToastService.Error(string.Join(", ", result.ErrorMessages));
                }
            });
        });

        _hubConnection.On<Result<ChatHub.MessageDeletedDto>>("MessageDeleted", result =>
        {
            InvokeAsync(() =>
            {
                if (result.Success)
                {
                    Console.WriteLine($"Deleted message via SignalR: {result.Data!.MessageId}");
                    State.RemoveMessage(result.Data!.Conversation, result.Data!.MessageId);
                }
                else
                {
                    Console.WriteLine($"Failed to delete message: {string.Join(", ", result.ErrorMessages)}");
                    ToastService.Error(string.Join(", ", result.ErrorMessages));
                }
            });
        });

        _hubConnection.On<Result<ConversationDto>>("ConversationCreated", result =>
        {
            InvokeAsync(async () =>
            {
                if (result.Success)
                {
                    Console.WriteLine($"Received conversation via SignalR: {result.Data!.Title}");
                    State.Conversations.Add(result.Data!);
                    await OnConversationSelected(result.Data!);
                }
                else
                {
                    Console.WriteLine($"Failed to create conversation: {string.Join(", ", result.ErrorMessages)}");
                    await ToastService.Error(string.Join(", ", result.ErrorMessages));
                }
            });
        });

        _hubConnection.On<Result<ConversationDto>>("ConversationUpdated", result =>
        {
            InvokeAsync(() =>
            {
                if (result.Success)
                {
                    Console.WriteLine($"Updated conversation via SignalR: {result.Data!.Title}");
                    State.UpdateConversation(result.Data!);
                }
                else
                {
                    Console.WriteLine($"Failed to update conversation: {string.Join(", ", result.ErrorMessages)}");
                    ToastService.Error(string.Join(", ", result.ErrorMessages));
                }
            });
        });

        _hubConnection.On<Result<object>>("ConversationDeleted", result =>
        {
            InvokeAsync(() =>
            {
                if (result.Success)
                {
                    var data = (JsonElement)result.Data!;
                    var conversationId = data.GetProperty("ConversationId").GetString()!;

                    Console.WriteLine($"Deleted conversation via SignalR: {conversationId}");
                    State.RemoveConversation(conversationId);
                }
                else
                {
                    Console.WriteLine($"Failed to delete conversation: {string.Join(", ", result.ErrorMessages)}");
                    ToastService.Error(string.Join(", ", result.ErrorMessages));
                }
            });
        });

        _hubConnection.On<Result<ConversationDto>>("ConversationLeft", result =>
        {
            InvokeAsync(async () =>
            {
                if (result.Success)
                {
                    Console.WriteLine($"Left conversation via SignalR: {result.Data!.Id}");

                    if (result.Data!.Participants.All(p => p.Id != State.UserId))
                    {
                        State.RemoveConversation(result.Data!.Id);
                    }
                    else
                    {
                        State.UpdateConversation(result.Data!);
                    }
                }
                else
                {
                    Console.WriteLine($"Failed to leave conversation: {string.Join(", ", result.ErrorMessages)}");
                    await ToastService.Error(string.Join(", ", result.ErrorMessages));
                }
            });
        });

        _hubConnection.Closed += error =>
        {
            Console.WriteLine($"Connection closed: {error?.Message}");
            return Task.CompletedTask;
        };

        _hubConnection.Reconnecting += error =>
        {
            Console.WriteLine($"Connection reconnecting: {error?.Message}");
            return Task.CompletedTask;
        };

        _hubConnection.Reconnected += async connectionId =>
        {
            Console.WriteLine($"Connection reconnected: {connectionId}");
            await JoinAllConversations();
        };

        try
        {
            await _hubConnection.StartAsync();
            Console.WriteLine($"SignalR Connected: {IsConnected}");

            await _hubConnection.InvokeAsync("Register", State.UserId);

            await JoinAllConversations();
            Console.WriteLine($"Joined all conversations");

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error connecting to SignalR: {ex.Message}");
        }
    }

    private async Task JoinAllConversations()
    {
        if (!IsConnected || _hubConnection is null) return;

        var tasks = State.Conversations.Select(conv => _hubConnection.InvokeAsync("JoinConversation", conv.Id)).ToList();

        if (tasks.Count > 0)
            await Task.WhenAll(tasks);
    }

    private Task ShowOffcanvas() => _offcanvas.Show();
    private Task ShowModal() => _modal.Show();

    private async Task HandleSubmit()
    {
        Console.WriteLine($"Sending message: {_messageText}");
        if (string.IsNullOrWhiteSpace(_messageText) || State.Selected is null) return;

        CreateChatMessageDto createChatMessageDto = new()
        {
            Content = _messageText,
            CreatorUserId = State.UserId!,
            ConversationId = State.Selected.Id,
            ReplyToMessageId = _replyToMessage?.Id
        };

        if (!CreateChatMessageDtoValidator.ValidateAsync(createChatMessageDto).Result.IsValid)
        {
            Console.WriteLine("Message validation failed.");
            return;
        }

        if (_hubConnection is not null)
        {
            await _hubConnection.SendAsync("CreateMessage", createChatMessageDto);
        }

        _messageText = null;
        _replyToMessage = null;

        Console.WriteLine($"Message sent successfully: {createChatMessageDto.Content}");
    }

    private async Task OnEditMessage(UpdateChatMessageDto msg)
    {
        if (!UpdateChatMessageDtoValidator.ValidateAsync(msg).Result.IsValid)
        {
            Console.WriteLine("Message validation failed.");
            return;
        }

        if (_hubConnection is not null)
        {
            await _hubConnection.SendAsync("UpdateMessage", msg);
        }
    }

    private async Task OnDeleteMessage(ChatMessageDto msg)
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.SendAsync("DeleteMessage", msg.Id);
        }
    }

    private Task OnReplyToMessage(ChatMessageDto msg)
    {
        _replyToMessage = msg;
        return Task.CompletedTask;
    }

    private Task CancelReply()
    {
        _replyToMessage = null;
        return Task.CompletedTask;
    }

    private async Task StartChat(string otherUserId)
    {
        var createConversationDto = new CreateConversationDto
        {
            CreatorUserId = State.UserId,
            ConversationType = ConversationType.Private,
            ParticipantIds = [otherUserId, State.UserId],
            TeamId = null,
            MatchId = null,
            Title = null
        };
        
        if (!CreateConversationDtoValidator.ValidateAsync(createConversationDto).Result.IsValid)
        {
            Console.WriteLine("Conversation validation failed.");
            return;
        }

        if (_hubConnection is not null)
        {
            await _hubConnection.SendAsync("CreateConversation", createConversationDto);
        }
    }

    private async Task LeaveConversation()
    {
        var id = State.Selected?.Id;
        if (id is null) return;

        if (_hubConnection is not null)
        {
            await _hubConnection.SendAsync("LeaveConversationAndNotify", id);
        }
    }

    private async Task DeleteConversation()
    {
        var id = State.Selected?.Id;
        if (id is null) return;
        if (_hubConnection is not null)
        {
            await _hubConnection.SendAsync("DeleteConversation", id);
        }
    }

    public async Task OnConversationSelected(ConversationDto conversation)
    {
        var messages = await ChatMessageService.GetChatMessagesAsync(conversation.Id, State.UserId, 1, State.NextChatMessagesCursor, CancellationToken.None);
        if (!messages.Success)
        {
            await ToastService.Error("Failed to load messages for conversation.");
            return;
        }
        State.Select(conversation, messages.Data!);
    }

    public async Task OnUpdateConversation(UpdateConversationDto updateConversationDto)
    {
        if (State.Selected is null)
        {
            await ToastService.Error("No conversation selected.");
            return;
        }

        if (!UpdateConversationDtoValidator.ValidateAsync(updateConversationDto).Result.IsValid)
        {
            Console.WriteLine("Conversation validation failed.");
            return;
        }

        var conv = await ConversationService.UpdateConversationAsync(updateConversationDto);
        if (!conv.Success)
        {
            Console.WriteLine("Failed to update conversation.");
            return;
        }

        State.UpdateConversation(conv.Data!);
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }
    }

}
