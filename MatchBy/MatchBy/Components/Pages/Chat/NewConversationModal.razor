@using MatchBy.Services.Users
@using Blazorise

<Modal @ref="ModalRef" Size="ModalSize.Small">
    <ModalContent Centered Class="rounded-3 shadow">
        <ModalHeader>
            <ModalTitle>New conversation</ModalTitle>
            <CloseButton/>
        </ModalHeader>

        <ModalBody Class="pt-2">

            <!-- Search -->
            <Field Class="mb-3">
                <TextEdit @bind-Text="_search"
                          Placeholder="Search for contacts"
                          Role="TextRole.Search"
                          Class="form-control-lg"/>
            </Field>

            @if (!_isLoading)
            {
                <!-- Contact list -->
                <ListGroup Mode="ListGroupMode.Selectable"
                           @bind-SelectedItem="_selectedItem" Flush
                           Style="max-height:320px; overflow:auto;">
                    @if ((Users?.Items?.Count ?? 0) == 0)
                    {
                        <ListGroupItem class="py-3 text-muted">No results</ListGroupItem>
                    }
                    else
                    {
                        @foreach (var u in (Users?.Items ?? Enumerable.Empty<ApplicationUser>()))
                        {
                            var photoUrl = u.ProfileImage?.Url ?? "/images/user-avatar.png";
                            <ListGroupItem Name="@u.Id" class="d-flex align-items-center gap-3 py-2 contact-item">
                                <Image Loading src="@photoUrl" Alt="@u.UserName" class="rounded-circle"
                                       style="width:32px; height:32px; object-fit:cover;"/>
                                <span class="fw-500">@u.UserName</span>
                            </ListGroupItem>
                        }
                    }
                </ListGroup>
            }
            else
            {
                <Div class="flex justify-center items-center" role="status" Style="height:320px; max-height: 320px; overflow:auto;">
                   <Loading></Loading>
                </Div>
            }

            <!-- Pagination -->
            <Pagination Alignment="Alignment.Center" Class="mt-3">
                <PaginationItem Disabled="@IsFirstPage">
                    <PaginationLink Clicked="@GoToPreviousPage">Previous</PaginationLink>
                </PaginationItem>

                @for (var p = 1; p <= _totalPages; p++)
                {
                    var pageNumber = p;
                    <PaginationItem Active="@(_currentPage == pageNumber)">
                        <PaginationLink Clicked="@(() => GoToPage(pageNumber))">@pageNumber</PaginationLink>
                    </PaginationItem>
                }

                <PaginationItem Disabled="@IsLastPage">
                    <PaginationLink Clicked="@GoToNextPage">Next</PaginationLink>
                </PaginationItem>
            </Pagination>

        </ModalBody>

        <ModalFooter Class="justify-content-between">
            <Button Color="Color.Primary" Class="px-4" Disabled="@(_selectedItem is null)" Clicked="@StartChat">New
                chat
            </Button>
            <Button Color="Color.Secondary" Outline Class="px-4" Clicked="@Hide">Cancel</Button>
        </ModalFooter>
    </ModalContent>
</Modal>

@code {
    private Modal ModalRef { get; set; } = new();
    private string _search = "";
    private string? _selectedItem;
    private int _currentPage = 1;

    [Parameter] public int PageSize { get; set; } = 4;

    [Parameter]
    public PagedResult<ApplicationUser> Users { get; set; } = new()
    {
        Items = [],
        TotalCount = 0
    };

    [Parameter] public EventCallback<string> OnCreate { get; set; }
    [Parameter] public EventCallback<UsersQuery> OnGetUsers { get; set; }

    private int _totalPages = 1;
    private bool _isLoading = false;

    private bool IsFirstPage => _currentPage == 1;
    private bool IsLastPage => _currentPage >= _totalPages;

    protected override void OnParametersSet()
    {
        var total = Users?.TotalCount ?? 0;
        var size = PageSize <= 0 ? 4 : PageSize;
        _totalPages = Math.Max(1, (int)Math.Ceiling((double)total / size));
    }

    private async Task Fetch()
    {
        if (_isLoading) return;
        _isLoading = true;
        try
        {
            var size = PageSize <= 0 ? 4 : PageSize;
            await OnGetUsers.InvokeAsync(new UsersQuery(_search, _currentPage, size));
            StateHasChanged();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task GoToPreviousPage()
    {
        if (_currentPage > 1)
        {
            _currentPage--;
            await Fetch();
        }
    }

    private async Task GoToNextPage()
    {
        if (_currentPage < _totalPages)
        {
            _currentPage++;
            await Fetch();
        }
    }

    private async Task GoToPage(int page)
    {
        if (page >= 1 && page <= _totalPages && page != _currentPage)
        {
            _currentPage = page;
            await Fetch();
        }
    }

    public async Task Show() => await ModalRef.Show();
    public async Task Hide() => await ModalRef.Hide();

    private async Task StartChat()
    {
        if (_selectedItem is not null)
        {
            await OnCreate.InvokeAsync(_selectedItem);
            await Hide();
        }
    }

    public record UsersQuery(string q, int page, int pageSize);

}
