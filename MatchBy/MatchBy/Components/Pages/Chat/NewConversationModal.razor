@using Blazorise

<Modal @ref="ModalRef" Size="ModalSize.Small">
    <ModalContent Centered Class="rounded-3 shadow">
        <ModalHeader>
            <ModalTitle>New conversation</ModalTitle>
            <CloseButton/>
        </ModalHeader>

        <ModalBody Class="pt-2">
            <!-- Search -->
            <Field Class="mb-3">
                <TextEdit @bind-Text="_search"
                          Placeholder="Search for contacts"
                          Role="TextRole.Search"
                          Class="form-control-lg"/>
            </Field>

            <!-- Contact list -->
            <ListGroup Mode="ListGroupMode.Selectable" @bind-SelectedItem="_selectedItem" Flush
                       Style="max-height:320px; overflow:auto;">
                <!--The username never is null, but i didnt have changed the default behaviour-->
                @foreach (var u in Users.Where(u => string.IsNullOrWhiteSpace(_search) ||
                                                    u.UserName!.Contains(_search, StringComparison.OrdinalIgnoreCase)))
                {
                    var photoUrl = u.ProfileImage?.Url ?? "/images/user-avatar.png";
                    <ListGroupItem Name="@u.Id" Class="d-flex align-items-center gap-3 py-2 contact-item">
                        <Image Loading src="@photoUrl"
                               Alt="@u.UserName"
                               Class="rounded-circle"
                               Style="width:32px; height:32px; object-fit:cover;"/>
                        <span class="fw-500">@u.UserName</span>
                    </ListGroupItem>
                }
            </ListGroup>
            <!--
            <nav class="flex justify-center" aria-label="Navigation of Users">
                <ul class="inline-flex -space-x-px text-sm">
                    <li>
                        <a href="#"
                           class="flex items-center justify-center px-3 h-8 ms-0 leading-tight text-gray-500 bg-white border border-e-0 border-gray-300 rounded-s-lg hover:bg-gray-100 hover:text-gray-700 dark:bg-gray-800 dark:border-gray-700 dark:text-gray-400 dark:hover:bg-gray-700 dark:hover:text-white">Previous</a>
                    </li>
                    <li>
                        <a href="#"
                           class="flex items-center justify-center px-3 h-8 leading-tight text-gray-500 bg-white border border-gray-300 hover:bg-gray-100 hover:text-gray-700 dark:bg-gray-800 dark:border-gray-700 dark:text-gray-400 dark:hover:bg-gray-700 dark:hover:text-white">1</a>
                    </li>
                    <li>
                        <a href="#"
                           class="flex items-center justify-center px-3 h-8 leading-tight text-gray-500 bg-white border border-gray-300 hover:bg-gray-100 hover:text-gray-700 dark:bg-gray-800 dark:border-gray-700 dark:text-gray-400 dark:hover:bg-gray-700 dark:hover:text-white">2</a>
                    </li>
                    <li>
                        <a href="#" aria-current="page"
                           class="flex items-center justify-center px-3 h-8 text-blue-600 border border-gray-300 bg-blue-50 hover:bg-blue-100 hover:text-blue-700 dark:border-gray-700 dark:bg-gray-700 dark:text-white">3</a>
                    </li>
                    <li>
                        <a href="#"
                           class="flex items-center justify-center px-3 h-8 leading-tight text-gray-500 bg-white border border-gray-300 hover:bg-gray-100 hover:text-gray-700 dark:bg-gray-800 dark:border-gray-700 dark:text-gray-400 dark:hover:bg-gray-700 dark:hover:text-white">4</a>
                    </li>
                    <li>
                        <a href="#"
                           class="flex items-center justify-center px-3 h-8 leading-tight text-gray-500 bg-white border border-gray-300 hover:bg-gray-100 hover:text-gray-700 dark:bg-gray-800 dark:border-gray-700 dark:text-gray-400 dark:hover:bg-gray-700 dark:hover:text-white">5</a>
                    </li>
                    <li>
                        <a href="#"
