@using MatchBy.DTOs.Chat.Conversations
@using Blazorise

<header class="flex-none bg-white dark:bg-neutral-900 border-b border-gray-200 dark:border-neutral-800 px-4 py-3">
    <div class="flex items-center gap-3">
        <img class="size-9 rounded-full flex-none"
             src="@(Conversation.ImageUrl ?? "/images/user-avatar.png")"
             alt="@Conversation.Title image" />
        <div class="min-w-0 flex-1">
            <div class="font-semibold truncate">@Conversation.Title</div>
        </div>
        <Button Clicked="OnOpenInfo" class="flex-none px-2 py-1 rounded hover:bg-gray-100 dark:hover:bg-neutral-800">
            <Icon Name="IconName.InfoCircle" />
        </Button>
    </div>
</header>

@code{
    [Parameter] public required ConversationDto Conversation { get; set; }
    [Parameter] public EventCallback OnOpenInfo { get; set; }
}
