@using MatchBy.DTOs.Chat.Conversations
@using Blazorise

<!-- Offcanvas: Conversation Info -->
<Offcanvas @ref="OffcanvasRef"
           ShowBackdrop
           Placement="Placement.End"
           Style="border-left: 1px solid var(--main); background-color: var(--background);"
           Class="h-full flex flex-col text-neutral-900 dark:text-neutral-100">

    <!-- Header fixo -->
    <OffcanvasHeader
        Class="flex items-center justify-between px-4 py-3 border-b border-[var(--main)]">
        <div class="flex items-center gap-2">
            <Icon Name="IconName.InfoCircle"/>
            <span class="font-medium">Conversation Info</span>
        </div>
        <CloseButton Class="!m-0" Clicked="@Hide"/>
    </OffcanvasHeader>

    <!-- Body: flex col, zona central com scroll -->
    <OffcanvasBody Class="flex flex-col flex-1 p-0 overflow-hidden">
        <!-- Hero (fixo) -->
        <div class="px-4 py-5 text-center border-b border-[var(--main)]">
            @if(SelectedConversation.Type == ConversationType.Private)
            {
                var otherParticipant = SelectedConversation.Participants.FirstOrDefault(p => p.Id != CurrentUserId);
                <Image
                    Src="@(otherParticipant?.ImageUrl ?? "/images/user-avatar.png")"
                    Alt="@SelectedConversation.Title"
                    Class="rounded-full mx-auto mb-3"
                    Style="width:72px;height:72px;object-fit:cover;"/>
                <div class="font-semibold">@otherParticipant?.DisplayName</div>
            }
            else
            {
                <Image
                    Src="@(SelectedConversation.ImageUrl ?? "/images/user-avatar.png")"
                    Alt="@SelectedConversation.Title"
                    Class="rounded-full mx-auto mb-3"
                    Style="width:72px;height:72px;object-fit:cover;"/>
                
                if (SelectedConversation.CreatorId == CurrentUserId && _isEditingTitle)
                {
                    <div class="flex items-center gap-2 justify-center">
                        <input type="text"
                               @bind="_newTitle"
                               @bind:event="oninput"
                               class="px-2 py-1 border rounded text-sm bg-[var(--background)] border-[var(--main)]"
                               placeholder="Conversation title"
                               style="max-width: 200px;" />
                        <button @onclick="SaveTitle"
                                class="p-1 text-green-600 hover:text-green-700">
                            <Icon Name="IconName.Check"/>
                        </button>
                        <button @onclick="CancelEditTitle"
                                class="p-1 text-red-600 hover:text-red-700">
                            <Icon Name="IconName.Times"/>
                        </button>
                    </div>
                }
                else
                {
                    <div class="flex items-center gap-2 justify-center">
                        <div class="font-semibold">@SelectedConversation.Title</div>
                        @if (SelectedConversation.CreatorId == CurrentUserId)
                        {
                            <button @onclick="StartEditTitle"
                                    class="p-1 text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">
                                <Icon Name="IconName.Edit"/>
                            </button>
                        }
                    </div>
                }
            }
            <div class="text-xs text-gray-500 dark:text-gray-400 mt-1">
                Updated @SelectedConversation.LastMessageAtUtc.ToString()
            </div>
        </div>
        
        @if (SelectedConversation.Type != ConversationType.Private && SelectedConversation.CreatorId == CurrentUserId)
        {
            <div class="mt-3 text-center">
                <InputFile id="avatarInput"
                           class="hidden"
                           accept="image/*"
                           OnChange="OnImageSelected" />

                <label for="avatarInput"
                       class="inline-flex items-center gap-2 border rounded px-3 py-1.5 cursor-pointer
                      text-primary-600 dark:text-primary-300 border-primary-600/40
                      hover:bg-primary-50 dark:hover:bg-primary-900/20">
                    <Icon Name="IconName.Image" />
                    <span>Change Image</span>
                </label>
            </div>   
        }

        <!-- Conteúdo scrollável -->
        <div class="flex-1 overflow-y-auto">
            <!-- Stats -->
            <div class="px-4 py-4 border-b border-[var(--main)]">
                <div class="flex items-center justify-between">
                    <span class="text-sm text-gray-500 dark:text-gray-400">Messages</span>
                    <span class="font-semibold">@SelectedConversation.MessagesCount</span>
                </div>
                <div class="flex items-center justify-between mt-2">
                    <span class="text-sm text-gray-500 dark:text-gray-400">Participants</span>
                    <span class="font-semibold">@SelectedConversation.Participants.Count</span>
                </div>
            </div>

            <!-- Members -->
            <div class="px-4 py-4 border-b border-[var(--main)]">
                <div class="font-semibold mb-2">Members</div>
                <ListGroup Flush Style="background-color: var(--background);border-width: 0;" >
                    @foreach (var p in SelectedConversation.Participants)
                    {
                        var photo = p.ImageUrl ?? "/images/user-avatar.png";
                        var isOwner = p.Id == SelectedConversation.CreatorId;
                        <ListGroupItem Class="!p-0">
                            <div class="flex items-center gap-3 px-2 py-2">
                                <Image Src="@photo"
                                       Alt="@p.Username"
                                       Class="rounded-full"
                                       Style="width:32px;height:32px;object-fit:cover;"/>
                                <div class="flex flex-col">
                                    <span class="font-medium">@p.DisplayName</span>
                                </div>
                                @if (isOwner)
                                {
                                    <span
                                        class="ml-auto inline-flex items-center rounded-full bg-indigo-100 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300 px-2 py-0.5 text-[11px]">
                                            Owner
                                        </span>
                                }
                            </div>
                        </ListGroupItem>
                    }
                </ListGroup>
            </div>
        </div>

        <!-- Ações (fixas em baixo) -->
        <div class="px-4 py-4 border-t border-[var(--main)]">
            <div class="grid gap-2">
                @if (SelectedConversation.Type != ConversationType.Private)
                {
                    <Button Color="Color.Warning"
                            Outline
                            Class="w-full !py-2.5"
                            Clicked="@OnLeaveConversation">
                        <div class="flex items-center justify-center gap-2">
                            <Icon Name="IconName.ArrowRight"/>
                            <span>Leave conversation</span>
                        </div>
                    </Button>
                }

                <Button Color="Color.Danger"
                        Class="w-full !py-2.5"
                        Clicked="@OnDeleteConversation">
                    <div class="flex items-center justify-center gap-2">
                        <Icon Name="IconName.Remove"/>
                        <span>Delete conversation</span>
                    </div>
                </Button>
            </div>
        </div>
    </OffcanvasBody>
</Offcanvas>

@code
{
    private bool _isEditingTitle;
    private string _newTitle = string.Empty;
    private Offcanvas OffcanvasRef { get; set; } = new();
    [Parameter] public required ConversationDto SelectedConversation { get; set; }
    [Parameter] public EventCallback OnLeaveConversation { get; set; }
    [Parameter] public EventCallback OnDeleteConversation { get; set; }
    [Parameter] public EventCallback<UpdateConversationDto> OnImageSubmit { get; set; }
    [Parameter] public EventCallback<UpdateConversationDto> OnTitleUpdate { get; set; }
    [Parameter] public EventCallback<string> OnSearchUsers { get; set; }
    [Parameter] public required string CurrentUserId { get; set; }

    public async Task Hide() => await OffcanvasRef.Hide();
    public async Task Show() => await OffcanvasRef.Show();

    private async Task OnImageSelected(InputFileChangeEventArgs e)
    {
        UpdateConversationDto dto = new()
        {
            Title = SelectedConversation.Title,
            ConversationId = SelectedConversation.Id,
            File = e.File,
            CreatorUserId = CurrentUserId,
            ParticipantIds = SelectedConversation.Participants.Select(p => p.Id).ToList()
        };
        await UpdateConversation(dto);
    } 
    
    private void StartEditTitle()
    {
        _newTitle = SelectedConversation.Title ?? string.Empty;
        _isEditingTitle = true;
    }

    private void CancelEditTitle()
    {
        _isEditingTitle = false;
        _newTitle = string.Empty;
    }
    
    private async Task SaveTitle()
    {
        if (string.IsNullOrWhiteSpace(_newTitle))
        {
            CancelEditTitle();
            return;
        }

        UpdateConversationDto dto = new()
        {
            ConversationId = SelectedConversation.Id,
            Title = _newTitle.Trim(),
            CreatorUserId = CurrentUserId,
            ParticipantIds = SelectedConversation.Participants.Select(p => p.Id).ToList()
        };

        await UpdateConversation(dto);
        _isEditingTitle = false;
    }

    private async Task UpdateConversation(UpdateConversationDto dto) => await OnImageSubmit.InvokeAsync(dto);
}
