@using MatchBy.DTOs.Chat.Messages
@using Blazorise

<footer class="flex-none bg-white dark:bg-neutral-900 border-t border-[var(--main)] px-4 py-3">
    <div class="flex flex-col gap-2">
        @if (ReplyTo is not null)
        {
            <div
                class="flex items-center gap-2 px-3 py-2 bg-gray-100 dark:bg-neutral-800 border-l-4 border-[var(--main)] rounded">
                <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-1">
                        <Icon Name="IconName.Reply" Class="text-indigo-600"/>
                        <span class="text-xs font-semibold text-indigo-600 dark:text-indigo-400">
                            Replying to @ReplyTo.Sender.DisplayName
                        </span>
                    </div>
                    <p class="text-sm text-gray-600 dark:text-gray-400 truncate">@ReplyTo.Content</p>
                </div>
                <button @onclick="CancelReply"
                        class="shrink-0 p-1 hover:bg-gray-200 dark:hover:bg-neutral-700 rounded transition-colors">
                    <svg class="w-5 h-5 text-gray-500 dark:text-gray-400" fill="none"
                         stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>
        }

        <div class="flex flex-row gap-2">
            <InputTextArea Value="@Text"
                           ValueChanged="TextChanged"
                           ValueExpression="() => Text"
                           rows="1"
                           placeholder="Write a message..."
                           class="ms-11 md:ms-0 w-full resize-none rounded-lg border border-[var(--main)] bg-[var(--section-secondary)]
                        text-[var(--text)]
                        focus:border-[var(--main)]
                        focus:ring-1 focus:ring-[var(--main)] px-3 py-2 outline-none transition-shadow"/>
            <Button Clicked="Send"
                    class="shrink-0 rounded-lg px-4 py-2 text-[var(--text-contrast)] bg-[var(--main)] hover:bg-[var(--main-hover)] transition-colors">
                Send
            </Button>
        </div>
    </div>
</footer>

@code{
    [Parameter] public string Text { get; set; } = "";
    [Parameter] public EventCallback<string?> TextChanged { get; set; }
    [Parameter] public ChatMessageDto? ReplyTo { get; set; }
    [Parameter] public EventCallback OnCancelReply { get; set; }
    [Parameter] public EventCallback OnSend { get; set; }

    private Task Send() => OnSend.InvokeAsync();
    private Task CancelReply() => OnCancelReply.InvokeAsync();

}
